GOOGLE_API_KEY=

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Leave blank to use default BAAI/bge-m3, or set a custom HuggingFace model name
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3

# Reranker — cross-encoder model for precision improvement after vector retrieval
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
USE_RERANKER=true
# Sigmoid-normalized score 0–1. Chunks below this score are excluded from context.
# Lower = more permissive (fewer "no result"), higher = stricter (less noise).
RERANKER_MIN_SCORE=0.3

DATABASE_URL=sqlite:///data/sqlite/hr.db
CHROMA_PERSIST_DIR=data/chroma
DOCS_DIR=data/docs

APP_ENV=development
APP_DEBUG=true
